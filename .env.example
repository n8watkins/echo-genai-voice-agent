# Gemini API key — server demo-key fallback (optional; BYOK preferred).
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id (optional). Defaults to gemini-3.1-flash-lite.
ECHO_MODEL=

# Optional — enables the web_search tool via Tavily (https://app.tavily.com,
# free tier ~1,000 searches/month). Without it, web_search degrades to model knowledge.
TAVILY_API_KEY=

# Optional — enables the on-device wake-word toggle ("Computer").
# Get a free access key at https://console.picovoice.ai/. Without it the wake-word
# toggle renders disabled with a hint; everything else works unchanged.
# NOTE: the ~1MB acoustic model public/models/porcupine_params.pv is NOT committed.
# If you enable the wake word, fetch it once (see the README "Wake word" section):
#   curl -L -o public/models/porcupine_params.pv \
#     https://raw.githubusercontent.com/Picovoice/porcupine/master/lib/common/porcupine_params.pv
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# Optional — saving conversations (Turso/libSQL). Without these, conversations
# are in-memory only (nothing is stored). Free DB at https://turso.tech.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional — GitHub sign-in (Auth.js); gates conversation saving. Register an
# OAuth app at https://github.com/settings/developers (callback URL:
# <app-url>/api/auth/callback/github). AUTH_SECRET = any random string
# (e.g. `openssl rand -base64 32`). Without these, sign-in is hidden.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET=
# Production only — canonical app URL Auth.js uses for OAuth callbacks
# (e.g. https://your-app.onrender.com). Leave blank locally (auto-inferred);
# REQUIRED on Render or Auth.js infers localhost and the GitHub callback breaks.
AUTH_URL=

# App URL + port
NEXT_PUBLIC_APP_URL=http://localhost:3200
PORT=3200
