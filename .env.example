# Gemini API key — server demo-key fallback (optional; BYOK preferred).
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id (optional). Defaults to gemini-3.1-flash-lite.
ECHO_MODEL=

# Optional — for the web_search tool (Google Programmable Search).
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Optional — enables the on-device wake-word toggle ("Computer").
# Get a free access key at https://console.picovoice.ai/. Without it the wake-word
# toggle renders disabled with a hint; everything else works unchanged.
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# App URL + port
NEXT_PUBLIC_APP_URL=http://localhost:3200
PORT=3200
